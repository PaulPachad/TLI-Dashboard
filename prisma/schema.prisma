// ==============================================================================
// TLI Leverage Dashboard — Production PostgreSQL Schema
// ==============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Models ---

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  role         String   @default("CLIENT")

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  actions Action[] @relation("CreatedByUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id              String  @id @default(cuid())
  name            String
  company         String?
  email           String
  title           String?
  signature       String?
  linkedinUrl     String?
  schedulingLink  String?
  defaultHashtags String? @default("#AuthorityMagazine #ThoughtLeadership #Leadership #Interview")
  defaultSignoff  String? @default("Warmly")
  replyToEmail    String?
  topicsSheetUrl  String?

  users        User[]
  sheetSources SheetSource[]
  interviews   Interview[]
  actions      Action[]
  topics       Topic[]
  events       Event[]
  automationProfiles AutomationProfile[]
  automationMailboxes AutomationMailbox[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SheetSource {
  id            String  @id @default(cuid())
  clientId      String
  sheetUrl      String
  spreadsheetId String
  gid           String?
  sheetTitle    String?

  lastSyncedAt DateTime?

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  interviews Interview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model Interview {
  id            String @id @default(cuid())
  clientId      String
  sheetSourceId String?
  sourceRowNumber Int?
  sourceRowHash String?

  // --- Core interview data ---
  intervieweeName    String
  intervieweeCompany String?
  intervieweeEmail   String?
  intervieweeTitle   String?
  companyEmployeeCount Int?
  companyRevenueUsd Float?
  largestSocialFollowerCount Int?
  prominenceNotes String?
  publicistName      String?
  publicistEmail     String?
  topic              String?

  // --- Links ---
  articleUrl      String
  buzzfeedUrl     String?
  interviewDocUrl String?

  // --- Media ---
  image1Url      String?
  image2Url      String?
  extraImagesUrl String?
  videoUrl       String?

  // --- Social ---
  linkedinUrl String?
  twitterUrl  String?

  // --- Imported status (from original sheet) ---
  liveEmailStatusImported     String?
  pressFollowupStatusImported String?
  estimatedPublishDate        DateTime?

  // --- Relationships ---
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sheetSource SheetSource? @relation(fields: [sheetSourceId], references: [id], onDelete: SetNull)
  actions     Action[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sheetSourceId, sourceRowNumber])
  @@unique([clientId, articleUrl])
  @@index([clientId])
  @@index([sheetSourceId])
}

model Action {
  id          String       @id @default(cuid())
  clientId    String
  interviewId String
  actionType  String
  status      String @default("SUCCESS")

  // --- Email-specific ---
  recipient String?
  cc        String?
  subject   String?
  body      String?

  // --- LinkedIn-specific ---
  generatedText   String?
  linkedinPostUrl String?

  // --- General ---
  metadataJson Json?
  note         String?

  createdByUserId String?
  createdByUser   User?  @relation("CreatedByUser", fields: [createdByUserId], references: [id])

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([interviewId])
  @@index([clientId])
  @@index([actionType])
}

model Topic {
  id                 String  @id @default(cuid())
  clientId           String
  
  title              String
  sourceRequests     String?
  responses          String?
  interviewQuestions String?

  client             Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([clientId])
}

model Event {
  id                 String  @id @default(cuid())
  clientId           String
  
  eventName          String
  date               String?
  location           String?
  status             String?
  contactInfo        String?

  client             Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([clientId])
}

model AutomationProfile {
  id            String  @id @default(cuid())
  clientId      String?
  name          String  @default("Authority Magazine Automation")
  description   String?

  isEnabled            Boolean @default(false)
  globalKillSwitch     Boolean @default(false)
  mode                 String  @default("DRAFT_ONLY")
  checkIntervalSeconds Int     @default(120)
  maxEmailsPerRun      Int     @default(30)
  matchThreshold       Int     @default(90)
  multipleChoiceGap    Int     @default(6)
  maxMatches           Int     @default(3)
  activeTopicLimit     Int?
  topicSourceType      String  @default("LOCAL_JSON")
  topicSourceUrl       String?
  formSheetUrl         String?
  blockedSendersJson   Json?
  blockedDomainsJson   Json?
  skipPhrasesJson      Json?
  configVersion        Int     @default(1)

  client       Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  mailboxes    AutomationMailbox[]
  templates    AutomationTemplate[]
  rules        AutomationRule[]
  runs         AutomationRun[]
  draftLogs    AutomationDraftLog[]
  learnedRules LearnedRule[]
  suppressions SuppressionEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model AutomationMailbox {
  id           String  @id @default(cuid())
  profileId    String
  clientId     String?
  label        String
  emailAddress String
  workflowType String

  isEnabled       Boolean @default(false)
  authStatus      String  @default("UNKNOWN")
  bridgeStatus    String  @default("NEVER_CONNECTED")
  lastHeartbeatAt DateTime?
  lastRunAt       DateTime?
  lastError       String?

  bridgeTokenHash      String? @unique
  bridgeTokenPreview   String?
  bridgeTokenRotatedAt DateTime?

  profile   AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  client    Client?           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  runs      AutomationRun[]
  draftLogs AutomationDraftLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, emailAddress])
  @@index([profileId])
  @@index([clientId])
}

model AutomationTemplate {
  id                   String @id @default(cuid())
  profileId            String
  templateKey          String
  name                 String
  subject              String?
  body                 String
  allowedVariablesJson Json?
  isEnabled            Boolean @default(true)
  version              Int     @default(1)

  profile AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, templateKey])
  @@index([profileId])
}

model AutomationRule {
  id          String  @id @default(cuid())
  profileId   String
  ruleType    String
  pattern     String
  action      String
  notes       String?
  isEnabled   Boolean @default(true)
  metadataJson Json?

  profile AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([ruleType])
}

model AutomationRun {
  id             String @id @default(cuid())
  profileId      String
  mailboxId      String?
  trigger        String @default("BRIDGE")
  status         String @default("RUNNING")
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  emailsScanned  Int @default(0)
  draftsCreated  Int @default(0)
  skippedCount   Int @default(0)
  warningCount   Int @default(0)
  errorCount     Int @default(0)
  summary        String?
  metadataJson   Json?

  profile   AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  mailbox   AutomationMailbox? @relation(fields: [mailboxId], references: [id], onDelete: SetNull)
  draftLogs AutomationDraftLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([mailboxId])
  @@index([status])
  @@index([startedAt])
}

model AutomationDraftLog {
  id             String @id @default(cuid())
  profileId      String
  mailboxId      String?
  runId          String?
  workflowType   String
  status         String @default("DRAFT_CREATED")
  recipient      String?
  subject        String?
  gmailThreadId  String?
  gmailMessageId String?
  matchedTopic   String?
  matchedUrl     String?
  matchScore     Int?
  templateKey    String?
  configVersion  Int?
  reason         String?
  snippet        String?
  metadataJson   Json?

  profile AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  mailbox AutomationMailbox? @relation(fields: [mailboxId], references: [id], onDelete: SetNull)
  run     AutomationRun?     @relation(fields: [runId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([mailboxId])
  @@index([runId])
  @@index([gmailThreadId])
  @@index([createdAt])
}

model LearnedRule {
  id               String @id @default(cuid())
  profileId        String
  originalTopic    String
  normalizedTopic  String
  correctTopicName String
  correctDocId     String?
  matchType        String @default("learned")
  source           String @default("local_autoresponder")
  confidence       Int?
  isEnabled        Boolean @default(true)

  profile AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, normalizedTopic])
  @@index([profileId])
}

model SuppressionEntry {
  id        String @id @default(cuid())
  profileId String
  kind      String
  value     String
  reason    String?
  isEnabled Boolean @default(true)

  profile AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, kind, value])
  @@index([profileId])
}
